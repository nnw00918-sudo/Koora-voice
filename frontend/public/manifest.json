{
  "short_name": "Koora Voice",
  "name": "Koora Voice - صوت الكورة",
  "description": "الاستاد الرقمي لعشاق كرة القدم - غرف صوتية ومباريات حية",
  "icons": [
    {
      "src": "favicon.ico",
      "sizes": "64x64 32x32 24x24 16x16",
      "type": "image/x-icon"
    },
    {
      "src": "logo192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "logo192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "logo512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "logo512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "theme_color": "#020617",
  "background_color": "#020617",
  "lang": "ar",
  "dir": "rtl",
  "categories": ["social", "entertainment", "sports"],
  "id": "koora-voice-app",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "screenshots": [
    {
      "src": "logo512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "الصفحة الرئيسية"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "shortcuts": [
    {
      "name": "الغرف الصوتية",
      "short_name": "الغرف",
      "description": "انضم للغرف الصوتية",
      "url": "/dashboard",
      "icons": [{ "src": "logo192.png", "sizes": "192x192" }]
    },
    {
      "name": "المباريات",
      "short_name": "مباريات",
      "description": "تابع المباريات المباشرة",
      "url": "/matches",
      "icons": [{ "src": "logo192.png", "sizes": "192x192" }]
    },
    {
      "name": "الرسائل",
      "short_name": "رسائل",
      "description": "المحادثات الخاصة",
      "url": "/messages",
      "icons": [{ "src": "logo192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+kooravoice",
      "url": "/handle?url=%s"
    }
  ]
}
